# RepoWiki — SAP AI Core credentials
# Copy this file to .env and fill in your values:
#   cp .env.example .env   (macOS/Linux)
#   copy .env.example .env  (Windows)
#
# These are ONLY needed for AI-powered file summaries.
# All other features (diagrams, glossary, structure map) work without them (--offline flag).

AICORE_AUTH_URL=https://<your-subdomain>.authentication.<region>.hana.ondemand.com
AICORE_CLIENT_ID=<your-client-id>
AICORE_CLIENT_SECRET=<your-client-secret>
AICORE_BASE_URL=https://api.ai.<region>.aws.ml.hana.ondemand.com
AICORE_RESOURCE_GROUP=default
